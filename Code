#include <IRremote.hpp>

// ---------------- LED Pins ----------------

// Main Road
const int mainGreen = 2;
const int mainYellow = 3;
const int mainRed = 4;

// Ultrasonic
const int echoPin = 5;
const int trigPin = 6;

// IR Receiver
const int IR_PIN = 12;

// Side Road
const int sideRed = 9;
const int sideYellow = 10;
const int sideGreen = 11;

// ---------------- Settings ----------------

const int detectDistance = 5;   // centimeters

// Play/Pause button code
uint32_t PLAY_PAUSE_CODE = 0xBF40FF00;

//------------------------------------------------

long getDistance()
{
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);

  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);

  digitalWrite(trigPin, LOW);

  long duration = pulseIn(echoPin, HIGH, 25000);

  if (duration == 0)
    return 999;

  return duration * 0.034 / 2;
}

//------------------------------------------------

void allOff()
{
  digitalWrite(mainGreen, LOW);
  digitalWrite(mainYellow, LOW);
  digitalWrite(mainRed, LOW);

  digitalWrite(sideGreen, LOW);
  digitalWrite(sideYellow, LOW);
  digitalWrite(sideRed, LOW);
}

//------------------------------------------------

void normalState()
{
  allOff();

  digitalWrite(mainGreen, HIGH);
  digitalWrite(sideRed, HIGH);
}

//------------------------------------------------

void emergencyAllRed()
{
  // Main road
  if (digitalRead(mainGreen))
  {
    digitalWrite(mainGreen, LOW);
    digitalWrite(mainYellow, HIGH);
    delay(1500);
    digitalWrite(mainYellow, LOW);
  }

  // Side road
  if (digitalRead(sideGreen))
  {
    digitalWrite(sideGreen, LOW);
    digitalWrite(sideYellow, HIGH);
    delay(1500);
    digitalWrite(sideYellow, LOW);
  }

  digitalWrite(mainRed, HIGH);
  digitalWrite(sideRed, HIGH);
}

//------------------------------------------------

bool checkIR()
{
  if (IrReceiver.decode())
  {
    uint32_t code = IrReceiver.decodedIRData.decodedRawData;

    Serial.print("HEX Code: 0x");
    Serial.println(code, HEX);

    IrReceiver.resume();

    if (code == PLAY_PAUSE_CODE)
    {
      emergencyAllRed();

      // Hold all red
      delay(10000);

      // Resume normal operation
      normalState();

      return true;
    }
  }

  return false;
}

//------------------------------------------------

void switchToSideRoad()
{
  digitalWrite(mainGreen, LOW);

  digitalWrite(mainYellow, HIGH);
  delay(1500);

  digitalWrite(mainYellow, LOW);
  digitalWrite(mainRed, HIGH);

  delay(500);

  digitalWrite(sideRed, LOW);
  digitalWrite(sideGreen, HIGH);
}

//------------------------------------------------

void switchBackToMain()
{
  digitalWrite(sideGreen, LOW);

  digitalWrite(sideYellow, HIGH);
  delay(1500);

  digitalWrite(sideYellow, LOW);
  digitalWrite(sideRed, HIGH);

  delay(500);

  digitalWrite(mainRed, LOW);
  digitalWrite(mainGreen, HIGH);
}

//------------------------------------------------

void setup()
{
  pinMode(mainGreen, OUTPUT);
  pinMode(mainYellow, OUTPUT);
  pinMode(mainRed, OUTPUT);

  pinMode(sideGreen, OUTPUT);
  pinMode(sideYellow, OUTPUT);
  pinMode(sideRed, OUTPUT);

  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);

  Serial.begin(9600);

  IrReceiver.begin(IR_PIN, ENABLE_LED_FEEDBACK);

  normalState();
}

//------------------------------------------------

void loop()
{
  // Check for emergency at all times between cycles
  if (checkIR())
    return;

  long distance = getDistance();

  Serial.print("Distance: ");
  Serial.println(distance);

  if (distance <= detectDistance)
  {
    switchToSideRoad();

    // Keep side road green for 5 seconds,
    // but continuously check the remote.
    unsigned long startTime = millis();

    while (millis() - startTime < 5000)
    {
      if (checkIR())
        return;

      delay(10);
    }

    switchBackToMain();
  }

  delay(50);
}
